# Main AI engine (recommended): free Gemini key from https://aistudio.google.com/apikey
# Big free allowance — long policy wordings are read in full.
GEMINI_API_KEY=your_gemini_api_key_here

# Backup AI engine: free Groq key from https://console.groq.com (starts with gsk_)
# The app works with either key alone; with both it falls back automatically.
GROQ_API_KEY=your_groq_api_key_here

# Optional overrides — only needed if a provider retires the built-in models.
# See MAINTENANCE.md.
# GEMINI_MODEL=gemini-2.5-flash
# TEXT_MODEL=openai/gpt-oss-120b        (Groq text; names: https://console.groq.com/docs/models)
# VISION_MODEL=qwen/qwen3.6-27b         (Groq vision)
